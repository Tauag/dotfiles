{
  "model": "opus",
  "enabledPlugins": {
    "eng@january-claude-code-plugins": true
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(git describe:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(npm ls:*)",
      "Bash(npm run:*)",
      "Bash(rg:*)",
      "Bash(ruff:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tree:*)",
      "Bash(uv:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "WebSearch",
      "WebFetch",
      "mcp__claude_ai_Linear__get_issue"
    ],
    "deny": [],
    "ask": []
  },
  "alwaysThinkingEnabled": true,
  "fastMode": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  }
}
